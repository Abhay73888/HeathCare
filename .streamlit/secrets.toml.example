# ╔══════════════════════════════════════════════════════════════╗
# ║  🔵 Google Login Setup — MediMate AI                          ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Is file ko COPY karke naam do:  .streamlit/secrets.toml
# (secrets.toml kabhi git me commit NAHI hota — .gitignore me hai)
#
# ── Google se client_id/secret kaise milega? (5 min ka kaam) ──
#  1. https://console.cloud.google.com/ kholo → naya project banao
#  2. "APIs & Services" → "OAuth consent screen" → External → app name do
#  3. "Credentials" → "Create Credentials" → "OAuth client ID"
#     → Application type: "Web application"
#  4. "Authorized redirect URIs" me EXACTLY ye daalo:
#       Local:  http://localhost:8501/oauth2callback
#       Cloud:  https://TUMHARI-APP.streamlit.app/oauth2callback
#  5. Client ID + Client Secret copy karke neeche paste karo. Done! 🎉
#
# cookie_secret = koi bhi lambi random string (session cookies sign karne ke liye)
# Generate karne ke liye terminal me:  python -c "import secrets; print(secrets.token_hex(32))"

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "yahan-koi-bhi-lambi-random-string-daalo"
client_id = "xxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxx"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# ── Streamlit Cloud pe deploy karte waqt ──
# App Settings → Secrets me YAHI content paste karo, bas redirect_uri
# apne cloud URL wala kar dena:
#   redirect_uri = "https://TUMHARI-APP.streamlit.app/oauth2callback"

# ╔══════════════════════════════════════════════════════════════╗
# ║  📱 Phone OTP Login — real SMS ke liye (OPTIONAL)             ║
# ╚══════════════════════════════════════════════════════════════╝
# Bina is setup ke bhi Phone login CHALEGA — DEMO mode me OTP
# screen pe hi dikh jayega (testing ke liye perfect 🧪).
# Real SMS chahiye to https://www.twilio.com se free trial account
# banao aur ye 3 cheezein yahan daalo:

[sms]
twilio_sid = "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
twilio_token = "your_auth_token_here"
twilio_from = "+1xxxxxxxxxx"   # Twilio wala phone number
