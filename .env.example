# ── MediMate AI — environment variables ──
# 1. Copy this file to a new file named ".env"
# 2. Paste your real keys below (leave blank to run that feature in offline mode)
# 3. NEVER commit your .env file to git!
#
# Every key is OPTIONAL — the app runs without any of them (offline mode).
# Add keys one by one to unlock more features; no code changes needed.

# ── Core AI ──────────────────────────────────────────────
# Groq -> the AI brain (free: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

GROQ_MODEL=llama-3.3-70b-versatile

# Serper -> live web search (free: https://serper.dev)
SERPER_API_KEY=your_serper_key_here

# ── Extra features (all free tiers) ──────────────────────
# OpenWeather -> weather + air-quality (AQI) health alerts
#   (free: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key_here


# USDA FoodData Central -> nutrition lookup for any food
#   (free: https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=your_usda_key_here



# NewsAPI -> latest health news headlines
#   (free: https://newsapi.org/register)
NEWSAPI_KEY=your_newsapi_key_here


# ── SMS medicine reminders (Twilio — free trial) ─────────
#   (https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Preferences ──────────────────────────────────────────
DEFAULT_COUNTRY=India
DEFAULT_CITY=Delhi
